# GPU Bringup Daily Status Tracker - Environment Configuration
# 复制此文件为 .env 并根据实际需求修改配置

# ============ 服务器配置 ============
# 服务器端口 (默认：3000)
PORT=3000

# 运行环境 (development/production)
NODE_ENV=production

# ============ 日志配置 ============
# 日志保留天数 (默认：30 天)
LOG_RETENTION_DAYS=30

# ============ 安全配置 ============
# Session 过期时间 (毫秒，默认：24 小时 = 86400000)
# SESSION_TIMEOUT=86400000

# ============ 备份配置 ============
# 是否启用自动备份 (默认：true)
# AUTO_BACKUP=true

# 备份保留数量 (默认：7)
# BACKUP_RETENTION=7
